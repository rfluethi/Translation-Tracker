msgid "Translation Tracker"
msgstr "Translation Tracker"

msgid "Shows the translation progress of learn.wordpress.org as a dashboard. Shortcode: [translation_tracker]"
msgstr "Zeigt den Übersetzungsfortschritt von learn.wordpress.org als Dashboard an. Shortcode: [translation_tracker]"

msgid "Translation Tracker – Settings"
msgstr "Translation Tracker – Einstellungen"

msgid "Cache cleared. Data will be reloaded on next page view."
msgstr "Cache geleert. Die Daten werden beim nächsten Seitenaufruf neu geladen."

msgid "Mode: GitHub Project V2 (GraphQL)"
msgstr "Modus: GitHub Project V2 (GraphQL)"

msgid "Items from the GitHub Project are filtered by Locale. This mode requires a GitHub Token with \"project\" scope."
msgstr "Items aus dem GitHub-Projekt werden nach Locale gefiltert. Dieser Modus erfordert ein GitHub-Token mit «project» Scope."

msgid "Mode: GitHub REST API"
msgstr "Modus: GitHub REST API"

msgid "Issues are filtered by label from the repository. Enter a project number to switch to Project mode (locale:German)."
msgstr "Issues werden nach Label aus dem Repository gefiltert. Trage eine Projekt-Nummer ein, um in den Project-Modus (locale:German) zu wechseln."

msgid "GitHub Project V2 – Locale Filter (recommended)"
msgstr "GitHub Project V2 – Locale-Filter (empfohlen)"

msgid "Corresponds to the filter \"locale:German\" in the GitHub project view."
msgstr "Entspricht dem Filter «locale:German» in der GitHub-Projektansicht."

msgid "GitHub Organisation"
msgstr "GitHub Organisation"

msgid "Project Number"
msgstr "Projekt-Nummer"

msgid "From the project URL: %s. Set to 0 to use REST API mode."
msgstr "Aus der Projekt-URL: %s. Auf 0 setzen, um den REST-API-Modus zu verwenden."

msgid "Locale Filter"
msgstr "Locale-Filter"

msgid "Value of the project field \"Locale\". Corresponds to locale:German in View 12. Leave empty to show all locales."
msgstr "Wert des Projekt-Felds «Locale». Entspricht locale:German in View 12. Leer lassen = alle Locales anzeigen."

msgid "GitHub REST API – Label Filter (Fallback)"
msgstr "GitHub REST API – Label-Filter (Fallback)"

msgid "Used when project number = 0."
msgstr "Wird verwendet, wenn Projekt-Nummer = 0."

msgid "GitHub Repository"
msgstr "GitHub Repository"

msgid "Issue Label"
msgstr "Issue Label"

msgid "General"
msgstr "Allgemein"

msgid "GitHub Token"
msgstr "GitHub Token"

msgid "Project mode: token with \"project\" scope (read-only is sufficient)."
msgstr "Project-Modus: Token mit «project» Scope (read-only reicht)."

msgid "REST mode: token with \"public_repo\" scope (optional, increases rate limit)."
msgstr "REST-Modus: Token mit «public_repo» Scope (optional, erhöht das Rate Limit)."

msgid "Create token"
msgstr "Token erstellen"

msgid "Cache (Minutes)"
msgstr "Cache (Minuten)"

msgid "Save Settings"
msgstr "Einstellungen speichern"

msgid "Refresh Data"
msgstr "Daten aktualisieren"

msgid "Clear the cached GitHub data so it is reloaded fresh on the next page view."
msgstr "Den zwischengespeicherten GitHub-Cache leeren, damit die Daten beim nächsten Seitenaufruf neu geladen werden."

msgid "Clear Cache & Reload Data"
msgstr "Cache leeren & Daten neu laden"

msgid "Usage"
msgstr "Verwendung"

msgid "Shortcode without parameters (uses above settings):"
msgstr "Shortcode ohne Parameter (verwendet obige Einstellungen):"

msgid "Project mode explicit:"
msgstr "Project-Modus explizit im Shortcode:"

msgid "REST mode explicit:"
msgstr "REST-Modus explizit im Shortcode:"

msgid "A GitHub Token is required for Project mode (GraphQL). Please add one under Settings → Translation Tracker."
msgstr "Für den Project-Modus (GraphQL) ist ein GitHub-Token erforderlich. Bitte unter Einstellungen → Translation Tracker eintragen."

